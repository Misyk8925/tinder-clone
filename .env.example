# =============================================================================
# Environment Variables for Dokploy Deployment
# Copy this file to .env and fill in all required values.
# NEVER commit the .env file with real secrets.
# =============================================================================

# ---------------------------------------------------------------------------
# DATABASE
# ---------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_strong_password

# ---------------------------------------------------------------------------
# REDIS
# ---------------------------------------------------------------------------
# Leave empty to disable Redis auth (not recommended for production)
REDIS_PASSWORD=change_me_redis_password

# ---------------------------------------------------------------------------
# KEYCLOAK
# ---------------------------------------------------------------------------
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change_me_keycloak_password

# ---------------------------------------------------------------------------
# KAFKA
# ---------------------------------------------------------------------------
# Set to the public IP/hostname of the server (only needed if external Kafka access is required)
KAFKA_EXTERNAL_HOST=localhost

# ---------------------------------------------------------------------------
# AWS / S3
# Use real AWS credentials for production, or leave defaults to use LocalStack
# ---------------------------------------------------------------------------
AWS_REGION=eu-north-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
# LocalStack endpoint — comment out and remove AWS_S3_ENDPOINT to use real AWS S3
AWS_S3_ENDPOINT=http://localstack:4566
AWS_S3_BUCKET=profiles-photos
MATCH_S3_BUCKET=match-conversation-photos

# ---------------------------------------------------------------------------
# STRIPE  (required for subscriptions-service)
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...
# Full URL of your server (used for Stripe redirect URLs)
STRIPE_SUCCESS_URL=https://yourdomain.com/success
STRIPE_CANCEL_URL=https://yourdomain.com/cancel

# ---------------------------------------------------------------------------
# CDN / CLOUDFRONT (optional)
# ---------------------------------------------------------------------------
CDN_ENABLED=false
CLOUDFRONT_DOMAIN=

# ---------------------------------------------------------------------------
# GATEWAY / TRAEFIK
# ---------------------------------------------------------------------------
# Public domain for the API gateway (used by Traefik in Dokploy)
APP_DOMAIN=yourdomain.com
# Port exposed by the gateway container (default 8222)
GATEWAY_PORT=8222

# ---------------------------------------------------------------------------
# TRACING (optional — Zipkin)
# ---------------------------------------------------------------------------
ZIPKIN_ENDPOINT=http://zipkin:9411/api/v2/spans

# ---------------------------------------------------------------------------
# mTLS CERTIFICATES
# The default classpath certs work for local/dev deployments.
# For production, generate proper certs with your server DNS names using
# deploy/generate-certs-docker.sh, then mount them and set paths below.
# ---------------------------------------------------------------------------

# profiles-service mTLS (HTTP internal + gRPC server)
# PROFILES_KEYSTORE_PATH=/certs/profiles-service.p12
# PROFILES_KEYSTORE_PASSWORD=changeit
# PROFILES_TRUSTSTORE_PATH=/certs/truststore.jks
# PROFILES_TRUSTSTORE_PASSWORD=changeit
# PROFILES_GRPC_KEYSTORE_PATH=/certs/profiles-service.p12
# PROFILES_GRPC_KEYSTORE_PASSWORD=changeit
# PROFILES_GRPC_TRUSTSTORE_PATH=/certs/truststore.jks
# PROFILES_GRPC_TRUSTSTORE_PASSWORD=changeit

# consumer-service mTLS (HTTP internal server)
# CONSUMER_KEYSTORE_PATH=/certs/consumer-service.p12
# CONSUMER_KEYSTORE_PASSWORD=changeit
# CONSUMER_TRUSTSTORE_PATH=/certs/truststore.jks
# CONSUMER_TRUSTSTORE_PASSWORD=changeit

# deck-service mTLS (HTTP client to profiles + consumer)
# DECK_KEYSTORE_PATH=/certs/deck-service.p12
# DECK_KEYSTORE_PASSWORD=changeit
# DECK_TRUSTSTORE_PATH=/certs/truststore.jks
# DECK_TRUSTSTORE_PASSWORD=changeit

# subscriptions-service gRPC mTLS client to profiles-service
# SUBSCRIPTIONS_GRPC_KEYSTORE_PATH=/certs/subscriptions-service.p12
# SUBSCRIPTIONS_GRPC_KEYSTORE_PASSWORD=changeit
# SUBSCRIPTIONS_GRPC_TRUSTSTORE_PATH=/certs/truststore.jks
# SUBSCRIPTIONS_GRPC_TRUSTSTORE_PASSWORD=changeit
# GRPC_MTLS_ENABLED=true
