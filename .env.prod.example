# Copy this file to .env.prod and set real values before production deployment.
# Never commit .env.prod.

POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-strong-password

# Per-service DB users (recommended for least privilege)
PROFILES_DB_USER=profiles_app
PROFILES_DB_PASSWORD=replace-with-strong-password
MATCH_DB_USER=match_app
MATCH_DB_PASSWORD=replace-with-strong-password
CONSUMER_DB_USER=consumer_app
CONSUMER_DB_PASSWORD=replace-with-strong-password
SUBSCRIPTIONS_DB_USER=subscriptions_app
SUBSCRIPTIONS_DB_PASSWORD=replace-with-strong-password
SWIPES_DB_USER=swipes_app
SWIPES_DB_PASSWORD=replace-with-strong-password

# mTLS certificates passwords
MTLS_KEYSTORE_PASSWORD=replace-with-keystore-password
MTLS_TRUSTSTORE_PASSWORD=replace-with-truststore-password

# Stripe settings
STRIPE_SECRET_KEY=replace-with-stripe-secret-key
STRIPE_WEBHOOK_SECRET=replace-with-stripe-webhook-secret
PROFILES_BASE_URL=https://profiles.your-domain.example/api/profiles
STRIPE_SUCCESS_URL=https://your-domain.example/subscriptions/success
STRIPE_CANCEL_URL=https://your-domain.example/subscriptions/cancel
STRIPE_PRICE_ID=replace-with-stripe-price-id

# AWS/S3 settings used by profiles/match services
AWS_ACCESS_KEY_ID=replace-with-aws-access-key-id
AWS_SECRET_ACCESS_KEY=replace-with-aws-secret-access-key
CLOUDFRONT_DOMAIN=https://cdn.your-domain.example
AWS_S3_BUCKET=replace-with-s3-bucket-name
AWS_REGION=replace-with-aws-region
CDN_ENABLED=true

# Keycloak settings
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=replace-with-strong-password
KEYCLOAK_URL=https://keycloak.your-domain.example
KEYCLOAK_REALM=spring
KEYCLOAK_CLIENT_ID=spring-app
KEYCLOAK_CLIENT_SECRET=replace-with-keycloak-client-secret

# Optional external Keycloak fields for no-keycloak profile
# KEYCLOAK_AUTH_SERVER_URL=https://keycloak.your-domain.example
# KEYCLOAK_JWK_SET_URI=https://keycloak.your-domain.example/realms/spring/protocol/openid-connect/certs
