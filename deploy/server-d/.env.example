# IP/hostname сервера с инфраструктурой (deploy/infrastructure)
INFRA_HOST=1.2.3.4

# IP/hostname Server B (profiles-service + gRPC живут там)
SERVER_B_HOST=5.6.7.8

POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_strong_password

# Stripe — получить на dashboard.stripe.com
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...
STRIPE_SUCCESS_URL=https://api.yourdomain.com/success
STRIPE_CANCEL_URL=https://api.yourdomain.com/cancel

GRPC_MTLS_ENABLED=true

# Пароль от mTLS-сертификатов (deploy/generate-certs-docker.sh создаёт с этим паролем)
CERTS_PASSWORD=changeit
